{
  "name": "CallBridge",
  "version": "1.1",
  "manifest_version": 3,
  "description": "PC to Phone Calling Extension",
  "permissions": ["contextMenus", "storage", "scripting", "alarms"],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "CallBridge"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
